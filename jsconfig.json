{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["frontend-admin/src/*"]
    },
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "frontend-admin/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "backend-demo",
    "dist"
  ]
}
